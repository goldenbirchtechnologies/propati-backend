# ═══════════════════════════════════════════════
# PROPATI BACKEND v2 — Environment Variables
# Copy to .env and fill all values before deploying
# ═══════════════════════════════════════════════

# ── Server ──────────────────────────────────────
PORT=3000
NODE_ENV=development           # development | production

# ── Clerk (Authentication) ──────────────────────
# dashboard.clerk.com → API Keys
# When set, Clerk handles auth. When unset, legacy JWT is used.
CLERK_SECRET_KEY=sk_live_your_clerk_secret_key
CLERK_PUBLISHABLE_KEY=pk_live_your_clerk_publishable_key

# ── Legacy JWT Secrets (used when Clerk is not configured) ─
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=generate_64_char_random_string_here
JWT_REFRESH_SECRET=generate_another_64_char_random_string
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Field-level encryption key for NIN/BVN/sensitive data
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=generate_32_byte_hex_key_here_64_chars_total

# ── PostgreSQL Database ──────────────────────────
# Option A: Full connection string (Railway/Render/Supabase provide this)
DATABASE_URL=postgresql://username:password@host:5432/propati_db

# Option B: Individual fields (use one or the other, not both)
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=propati_db
# DB_USER=propati_user
# DB_PASSWORD=your_db_password
# DB_SSL=true        # set true for cloud databases

# ── Cloudinary (File Uploads) ────────────────────
# Get from cloudinary.com → Dashboard
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
CLOUDINARY_FOLDER=propati            # organise files under this folder

# ── Paystack (Payments) ──────────────────────────
# Get from dashboard.paystack.com → Settings → API Keys
PAYSTACK_SECRET_KEY=sk_test_your_key_here
PAYSTACK_PUBLIC_KEY=pk_test_your_key_here
PAYSTACK_WEBHOOK_SECRET=your_webhook_secret

# ── NIMC (NIN Verification) ──────────────────────
# Apply at nimc.gov.ng/developers (takes 2-4 weeks)
NIMC_API_KEY=your_nimc_api_key
NIMC_BASE_URL=https://api.sandbox.nimc.gov.ng/v1

# ── Twilio (SMS) ─────────────────────────────────
# console.twilio.com
TWILIO_ACCOUNT_SID=your_account_sid
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# ── Resend (Email) ───────────────────────────────
# resend.com → API Keys
RESEND_API_KEY=re_your_resend_api_key
EMAIL_FROM=PROPATI <hello@propati.ng>

# ── File Upload Limits ───────────────────────────
MAX_FILE_SIZE_MB=10            # per image/document
MAX_VIDEO_SIZE_MB=100          # for QR proof videos

# ── Rate Limiting ────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000    # 15 minutes
RATE_LIMIT_MAX=300             # requests per window (global)
AUTH_RATE_LIMIT_MAX=10         # requests per window (login/signup)

# ── Sentry (Error Tracking) ──────────────────────
# sentry.io → Project Settings → DSN
SENTRY_DSN=https://your_key@sentry.io/your_project

# ── Frontend ─────────────────────────────────────
FRONTEND_URL=http://localhost:5500   # update to your domain in prod

# ── Admin ────────────────────────────────────────
ADMIN_EMAIL=admin@propati.ng
ADMIN_PASSWORD=change_this_before_deploying!
